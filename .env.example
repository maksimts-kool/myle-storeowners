# Copy to .env and fill in. Used by `docker compose` for the whole site.

# --- PostgreSQL (created by Compose) ---
POSTGRES_USER=storeowners
POSTGRES_PASSWORD=change-me
POSTGRES_DB=storeowners

# --- Where the site is published on the host ---
WEB_BIND_IP=127.0.0.1
WEB_PORT=8080

# --- Discord OAuth2 (reuse your existing Discord application) ---
# Discord Developer Portal -> your app -> OAuth2:
#   - add the redirect URI below under "Redirects"
#   - copy the Client ID and Client Secret
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Public origin of the site (browser-facing). Must match WEB_PORT above.
PUBLIC_BASE_URL=http://localhost:8080

# Comma-separated Discord user IDs that get game-owner (admin) access.
# Put your own Discord user ID here.
ADMIN_DISCORD_IDS=

# Long random string used to sign the session cookie (>= 16 chars).
SESSION_SECRET=replace-with-a-long-random-string

# --- Notifications via the bot (mylebot) ---
# The bot's /internal/notify endpoint and shared secret (= bot SITE_NOTIFY_SECRET).
# This also supplies the verified-member store-owner picker. Leave it empty to
# disable notifications and leave stores unassigned.
# If the bot runs in Docker on the same host, use host.docker.internal:
#   BOT_NOTIFY_URL=http://host.docker.internal:3000/internal/notify
BOT_NOTIFY_URL=
BOT_NOTIFY_SECRET=

# --- Uploads / cookies ---
# Max upload size in bytes (default 250 MB).
MAX_UPLOAD_BYTES=262144000
# auto | true | false. "auto" sets the Secure cookie flag when PUBLIC_BASE_URL is https.
COOKIE_SECURE=auto
