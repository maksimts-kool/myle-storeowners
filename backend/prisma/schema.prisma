generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StoreStatus {
  OPEN
  CLOSED
  ELECTION
}

enum VersionStatus {
  PENDING
  APPROVED
  DECLINED
  PUBLISHED
  SUPERSEDED
}

enum ApplicationStatus {
  APPLIED
  SELECTED
  NOT_SELECTED
  REMOVED
  CANCELLED
}

enum ElectionStatus {
  DRAFT // being prepared, invisible to members
  SCHEDULED // published, waiting for applicationsOpenAt
  RUNNING // inside the application and/or voting windows
  TALLYING // voting closed, winners computed, waiting for a game owner
  CLOSED // finished; owners assigned and store statuses restored
  CANCELLED // called off; votes voided and store statuses restored
}

model Store {
  code             String         @id // e.g. "A1".."B6" or any admin-created code
  floor            Int // 1 for A*, 2 for B*
  displayName      String
  status           StoreStatus    @default(OPEN)
  ownerDiscordId   String?
  ownerDisplayName String?
  storeIdentifier  String? // e.g. "A3.001.240325" from the in-game sign
  startingVersion  Int            @default(0) // last version represented by storeIdentifier; new uploads start after it
  room             Json? // room layout in studs: { width, depth, height, entrance, windows[] } — see services/room.ts
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  versions         StoreVersion[]
  templates        TemplateFile[]
  applications     StoreApplication[]
  votes            ElectionVote[]
  elections        ElectionStore[]

  @@index([ownerDiscordId])
}

/**
 * A scheduled election round. Everything members can do — applying and voting —
 * is gated by this row's windows, and `status` is advanced by the scheduler in
 * services/election-service.ts rather than by hand.
 */
model Election {
  id                  String         @id @default(cuid())
  title               String
  status              ElectionStatus @default(DRAFT)
  applicationsOpenAt  DateTime
  applicationsCloseAt DateTime
  votingOpensAt       DateTime
  votingClosesAt      DateTime
  createdByDiscordId  String
  closedAt            DateTime?
  closedByDiscordId   String?
  note                String? // shown to members on the elections page
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  stores              ElectionStore[]
  applications        StoreApplication[]
  votes               ElectionVote[]

  @@index([status, applicationsOpenAt])
}

/**
 * A store contested in one election. `previousStatus` is what the store's
 * status is restored to when the round closes without a winner or is cancelled.
 */
model ElectionStore {
  electionId          String
  election            Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  storeCode           String
  store               Store       @relation(fields: [storeCode], references: [code], onDelete: Cascade)
  previousStatus      StoreStatus @default(OPEN)
  winnerApplicationId String? // set when a game owner confirms the result

  @@id([electionId, storeCode])
  @@index([storeCode])
}

/** A verified member's request to manage one store within one election. */
model StoreApplication {
  id                    String            @id @default(cuid())
  storeCode             String
  store                 Store             @relation(fields: [storeCode], references: [code], onDelete: Cascade)
  electionId            String? // null only on rows that predate scheduled elections
  election              Election?         @relation(fields: [electionId], references: [id], onDelete: Cascade)
  applicantDiscordId    String
  applicantDisplayName  String
  applicantRobloxName   String?
  status                ApplicationStatus @default(APPLIED)
  resolvedAt            DateTime?
  resolvedByDiscordId   String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  votes                 ElectionVote[]

  // One application per member per round — a member who loses one election may
  // enter the next one.
  @@unique([electionId, applicantDiscordId])
  @@index([applicantDiscordId])
  @@index([storeCode, status, createdAt])
}

// Retained for schema-compatible deployments that previously created this
// table. Application eligibility is now determined only by StoreApplication.
model ElectionApplicationLock {
  discordId String   @id
  lockedAt  DateTime @default(now())
}

/** A verified member gets one vote for each store in an election. */
model ElectionVote {
  id             String           @id @default(cuid())
  storeCode      String
  store          Store            @relation(fields: [storeCode], references: [code], onDelete: Cascade)
  electionId     String? // null only on rows that predate scheduled elections
  election       Election?        @relation(fields: [electionId], references: [id], onDelete: Cascade)
  applicationId  String
  application    StoreApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  voterDiscordId String
  createdAt      DateTime         @default(now())

  @@unique([electionId, storeCode, voterDiscordId])
  @@index([applicationId])
}

model StoreVersion {
  id                  String        @id @default(cuid())
  storeCode           String
  store               Store         @relation(fields: [storeCode], references: [code], onDelete: Cascade)
  versionNumber       Int // increments per store
  status              VersionStatus @default(PENDING)
  fileName            String // original filename
  filePath            String // path under the store_files volume
  fileSize            BigInt
  checksum            String? // sha256 hex, computed while streaming
  uploadedByDiscordId String
  note                String? // owner's message
  reviewNote          String? // admin's approve/decline note
  reviewedByDiscordId String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([storeCode, versionNumber])
  @@index([storeCode, createdAt])
}

model TemplateFile {
  id                  String   @id @default(cuid())
  storeCode           String? // null = global template
  store               Store?   @relation(fields: [storeCode], references: [code], onDelete: Cascade)
  fileName            String
  filePath            String
  fileSize            BigInt
  uploadedByDiscordId String
  createdAt           DateTime @default(now())

  @@index([storeCode, createdAt])
}

model NotificationPreference {
  discordId           String   @id // the Discord user these preferences belong to
  submissionReceived  Boolean  @default(true)
  reviewNeeded        Boolean  @default(true)
  submissionApproved  Boolean  @default(true)
  submissionDeclined  Boolean  @default(true)
  submissionPublished Boolean  @default(true)
  applicationApplied     Boolean  @default(true)
  applicationSelected    Boolean  @default(true)
  applicationNotSelected Boolean @default(true)
  applicationRemoved     Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(cuid())
  discordId String
  kind      String
  storeCode String?
  success   Boolean
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
