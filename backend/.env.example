# Copy to backend/.env for running the backend directly in dev (`npm run dev`).
# For Docker, use the repo-root .env instead.

# Point at a Postgres you run locally (e.g. via `docker run postgres:17`).
DATABASE_URL=postgresql://storeowners:change-me@127.0.0.1:5432/storeowners?schema=public

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback
PUBLIC_BASE_URL=http://localhost:8080

ADMIN_DISCORD_IDS=
SESSION_SECRET=replace-with-a-long-random-string

BOT_NOTIFY_URL=
BOT_NOTIFY_SECRET=

# Store files live here in dev (relative to the backend/ folder).
STORE_FILES_DIR=./.data/store-files
MAX_UPLOAD_BYTES=262144000

API_HOST=0.0.0.0
API_PORT=3000
TRUST_PROXY=loopback
COOKIE_SECURE=false
